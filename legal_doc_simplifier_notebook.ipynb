    "from docx import Document\n",
    "\n",
    "def save_simplified_document(simplified_chunks, output_path=\"simplified_document.docx\"):\n",
    "    doc = Document()\n",
    "    \n",
    "    # Title\n",
    "    doc.add_heading(\"Simplified Legal Document\", level=0)\n",
    "    doc.add_paragraph(\"Generated by AI Legal Document Simplifier | For reference only — not legal advice.\")\n",
    "    doc.add_paragraph(\"\")  # spacing\n",
    "    \n",
    "    # Add each simplified chunk as a section\n",
    "    for i, section in enumerate(simplified_chunks, start=1):\n",
    "        doc.add_heading(f\"Section {i}\", level=2)\n",
    "        doc.add_paragraph(section)\n",
    "        doc.add_paragraph(\"\")  # spacing between sections\n",
    "    \n",
    "    doc.save(output_path)\n",
    "    print(f\"✅ Saved: {output_path}\")\n",
    "\n",
    "\n",
    "# Save it\n",
    "save_simplified_document(simplified_chunks, output_path=\"simplified_document.docx\")\n",
    "\n",
    "# Also create a plain text version\n",
    "full_simplified_text = \"\\n\\n\".join(\n",
    "    [f\"--- Section {i} ---\\n{s}\" for i, s in enumerate(simplified_chunks, start=1)]\n",
    ")\n",
    "\n",
    "with open(\"simplified_document.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "    f.write(full_simplified_text)\n",
    "\n",
    "print(\"✅ Also saved: simplified_document.txt\")\n",
    "print(f\"\\nTotal sections: {len(simplified_chunks)}\")\n",
    "print(f\"Preview of Section 1:\\n\\n{simplified_chunks[0][:500]}\")"
   ]
