    "from langchain_core.messages import SystemMessage, HumanMessage\n",
    "\n",
    "def simplify_chunk(chunk, llm):\n",
    "    messages = [\n",
    "        SystemMessage(content=\"\"\"You are a legal document simplifier. \n",
    "Your job is to convert complex legal text into simple, plain English that anyone can understand.\n",
    "- Use short sentences\n",
    "- Avoid legal jargon\n",
    "- Highlight any important obligations, deadlines, or penalties with a ⚠️ emoji\n",
    "- Be concise but don't miss key points\"\"\"),\n",
    "        \n",
    "        HumanMessage(content=f\"Simplify this legal text:\\n\\n{chunk}\")\n",
    "    ]\n",
    "    \n",
    "    response = llm.invoke(messages)\n",
    "    return response.content\n",
    "\n",
    "\n",
    "# Test on just the first 3 chunks first\n",
    "print(\"Processing first 3 chunks...\\n\")\n",
    "\n",
    "for i, chunk in enumerate(chunks[:3], start=1):\n",
