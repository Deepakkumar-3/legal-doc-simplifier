    "def detect_red_flags(chunks, llm):\n",
    "    red_flags = []\n",
    "    \n",
    "    for i, chunk in enumerate(chunks, start=1):\n",
    "        messages = [\n",
    "            SystemMessage(content=\"\"\"You are a legal risk analyst.\n",
    "Your job is to identify potentially risky, unfair, or important clauses in legal documents.\n",
    "Look for:\n",
    "- Auto-renewal clauses\n",
    "- Penalty or fine clauses\n",
    "- Data sharing or privacy concerns\n",
    "- Termination conditions\n",
    "- Hidden fees or charges\n",
    "- Liability limitations\n",
    "- Obligations on the user/tenant/customer\n",
    "\n",
    "If you find any red flags in the text, respond in this exact format:\n",
    "🚩 [Clause Type]: [One line explanation]\n",
    "\n",
    "If there are NO red flags in this chunk, respond with exactly: NONE\"\"\"),\n",
    "            \n",
    "            HumanMessage(content=f\"Analyze this chunk for red flags:\\n\\n{chunk}\")\n",
    "        ]\n",
    "        \n",
    "        response = llm.invoke(messages)\n",
    "        result = response.content.strip()\n",
    "        \n",
    "        if result != \"NONE\":\n",
    "            red_flags.append(f\"**Section {i}:**\\n{result}\")\n",
    "        \n",
    "        time.sleep(0.5)\n",
    "    \n",
    "    return red_flags\n",
    "\n",
    "\n",
    "# Run red flag detection\n",
    "print(\"🔍 Scanning for red flags...\\n\")\n",
    "red_flags = detect_red_flags(chunks, llm)\n",
    "\n",
    "print(f\"✅ Scan complete!\")\n",
    "print(f\"🚩 Total red flag sections found: {len(red_flags)}\\n\")\n",
    "\n",
    "# Preview first 5\n",
    "for flag in red_flags[:5]:\n",
