    "import time\n",
    "from IPython.display import clear_output\n",
    "\n",
    "def simplify_all_chunks(chunks, llm):\n",
    "    simplified_results = []\n",
    "    total = len(chunks)\n",
    "    \n",
    "    for i, chunk in enumerate(chunks, start=1):\n",
    "        try:\n",
    "            simplified = simplify_chunk(chunk, llm)\n",
    "            simplified_results.append(simplified)\n",
    "            \n",
    "            # Progress display\n",
    "            clear_output(wait=True)\n",
    "            percent = (i / total) * 100\n",
    "            bar = \"█\" * int(percent // 2) + \"░\" * (50 - int(percent // 2))\n",
    "            print(f\"Processing chunks... {i}/{total}\")\n",
    "            print(f\"[{bar}] {percent:.1f}%\")\n",
    "            \n",
    "            # Small delay to avoid hitting Groq rate limits\n",
    "            time.sleep(0.5)\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"⚠️ Error on chunk {i}: {e}\")\n",
    "            simplified_results.append(f\"[Could not process chunk {i}]\")\n",
    "            time.sleep(2) \n",
    "    \n",
    "    return simplified_results\n",
    "\n",
    "\n",
    "\n",
    "simplified_chunks = simplify_all_chunks(chunks, llm)\n",
    "\n",
    "print(\"\\n✅ All chunks processed!\")\n",
    "print(f\"Total simplified sections: {len(simplified_chunks)}\")"
   ]
