    "def generate_executive_summary(simplified_chunks, llm):\n",
    "    # Join first and last few chunks to capture intro + conclusion\n",
    "    # We can't send all 239 simplified chunks at once — too large\n",
    "    # So we sample strategically\n",
    "    \n",
    "    sampled = simplified_chunks[:5] + simplified_chunks[len(simplified_chunks)//2 - 2 : len(simplified_chunks)//2 + 2] + simplified_chunks[-5:]\n",
    "    combined = \"\\n\\n\".join(sampled)\n",
    "    \n",
    "    messages = [\n",
    "        SystemMessage(content=\"\"\"You are a professional document analyst.\n",
    "Your job is to write a clear, concise executive summary of a document.\n",
    "Structure your summary as:\n",
    "📌 **What this document is about** (2-3 sentences)\n",
    "📊 **Key highlights** (4-5 bullet points)\n",
    "📅 **Important figures or dates mentioned** (if any)\n",
    "🎯 **Who this document is relevant for** (1-2 sentences)\"\"\"),\n",
    "        \n",
    "        HumanMessage(content=f\"Write an executive summary based on these sections:\\n\\n{combined}\")\n",
    "    ]\n",
    "    \n",
    "    response = llm.invoke(messages)\n",
    "    return response.content\n",
    "\n",
    "\n",
    "# Generate summary\n",
    "print(\"📊 Generating executive summary...\\n\")\n",
    "executive_summary = generate_executive_summary(simplified_chunks, llm)\n",
    "\n",
    "print(\"EXECUTIVE SUMMARY:\")\n",
    "print(\"=\"*50)\n",
    "print(executive_summary)"
   ]
